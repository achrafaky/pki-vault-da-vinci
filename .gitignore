# Clés privées (SÉCURITÉ !) – on les exclut
*.key
*.key.pem

# Mais on autorise les certificats et CSR (sauf les clés)
# On ne va pas exclure *.pem, *.crt, *.csr globalement.
# On exclut seulement les clés privées.

# Python
venv/
__pycache__/
*.pyc

# Logs
logs/*.log

# Configuration
.env

# Base de données
*.db
*.sqlite3
pki_vault.db

# Temporaires
*.tmp
*.swp
.DS_Store

# Dossiers de build
build/
dist/
*.egg-info/
.eggs/

# IDE
.vscode/
.idea/

# Fichiers de test (optionnel)
test*.pem
mon_csr.pem

# CRL (on peut les garder)
# pki/*/crl/*.crl.pem

# On ne supprime pas pki/ pour que les certificats soient visibles
# mais on peut exclure les clés privées (déjà fait)
