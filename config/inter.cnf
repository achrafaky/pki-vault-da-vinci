[ ca ]
default_ca = CA_default

[ CA_default ]
dir               = ./pki/intermediate
certs             = $dir/certs
crl_dir           = $dir/crl
new_certs_dir     = $dir/newcerts
database          = $dir/db/index.txt
serial            = $dir/db/serial
RANDFILE          = $dir/private/.rand
private_key       = $dir/private/inter.key.pem
certificate       = $dir/certs/inter.crt.pem
crlnumber         = $dir/db/crlnumber
crl               = $dir/crl/inter.crl.pem
crl_extensions    = crl_ext
default_crl_days  = 7
default_md        = sha256
name_opt          = ca_default
cert_opt          = ca_default
default_days      = 365
preserve          = no
policy            = policy_loose
copy_extensions   = copy
rand_serial       = yes

[ policy_loose ]
countryName            = optional
stateOrProvinceName    = optional
organizationName       = optional
commonName             = supplied

[ req ]
default_bits        = 4096
distinguished_name  = req_distinguished_name
string_mask         = utf8only
default_md          = sha256

[ req_distinguished_name ]
countryName                  = Country Name
countryName_default          = MA
stateOrProvinceName          = State
stateOrProvinceName_default  = Tanger
organizationName             = Organization
organizationName_default     = PKI Vault Enterprise
commonName                   = Common Name
commonName_default           = PKI Intermediate CA

[ server_cert ]
basicConstraints       = CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = serverAuth

[ client_cert ]
basicConstraints       = CA:FALSE
keyUsage               = critical, digitalSignature, nonRepudiation
extendedKeyUsage       = clientAuth

[ crl_ext ]
authorityKeyIdentifier = keyid:always
